{
  "name": "my-website",
  "type": "module",
  "scripts": {
    "start": "node --watch server.ts",
    "generate": "node node_modules/@mastrojs/mastro/src/generator.js",
    "check": "tsc"
  },
  "dependencies": {
    "@mastrojs/markdown": "jsr:^0.2.2",
    "@mastrojs/mastro": "jsr:^0.8.9",
    "@remix-run/node-fetch-server": "^0.11",
    "reading-time": "^1.5.0",
    "satteri": "0.9.5",
    "satteri-expressive-code": "^0.1.17"
  },
  "devDependencies": {
    "@types/node": "^24",
    "typescript": "^5"
  },
  "engines": {
    "node": "24.x"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.x",
      "onFail": "download"
    }
  }
}
